{
  "name": "epr-backend-journey-tests",
  "version": "0.0.0",
  "type": "module",
  "description": "Test suite for Defra's Packaging Extended Producer Responsibilities service using Cucumber and API testing framework",
  "engines": {
    "node": ">=24.16.0 <25"
  },
  "author": "Defra DDTS",
  "license": "OGL-UK-3.0",
  "aliases": {
    "~": ".",
    "page-objects": "test/page-objects",
    "components": "test/components"
  },
  "scripts": {
    "clean": "rm -rf allure-results && rm -rf allure-report",
    "format:check": "prettier --check 'test/**/*.js' '**/*.{js,md,json,config.js}'",
    "format": "prettier --write 'test/**/*.js' '**/*.{js,md,json,config.js}'",
    "generate:spreadsheet:exporter": "node test/support/spreadsheet/summarylogs-spreadsheet-data-generator.js --wasteProcessingType=exporter",
    "generate:spreadsheet:input": "node test/support/spreadsheet/summarylogs-spreadsheet-data-generator.js --wasteProcessingType=reprocessorInput",
    "generate:spreadsheet:ors": "node ./data/ors-spreadsheet-generator.js",
    "generate:spreadsheet:output": "node test/support/spreadsheet/summarylogs-spreadsheet-data-generator.js --wasteProcessingType=reprocessorOutput",
    "generate:spreadsheet:regOnlyExporter": "node test/support/spreadsheet/summarylogs-spreadsheet-data-generator.js --wasteProcessingType=regOnlyExporter",
    "generate:spreadsheet:regOnlyReprocessor": "node test/support/spreadsheet/summarylogs-spreadsheet-data-generator.js --wasteProcessingType=regOnlyReprocessor",
    "generatedata:allMaterials:withLinking": "node ./data/all-materials-data-generator.js --with-linking",
    "generatedata:allMaterials": "node ./data/all-materials-data-generator.js ",
    "generatedata:allMaterialsMixed:withLinking": "node ./data/all-materials-mixed-data-generator.js --with-linking",
    "generatedata:allMaterialsMixed": "node ./data/all-materials-mixed-data-generator.js",
    "generatedata:withLinking": "node ./data/data-generator.js --with-linking",
    "generatedata": "node ./data/data-generator.js",
    "lint:fix": "eslint . --fix",
    "lint:types": "tsc -p jsconfig.typecheck.json",
    "lint": "eslint .",
    "postinstall": "npm run setup:husky",
    "report:publish": "npm run report; ./bin/publish-tests.sh",
    "report": "allure generate allure-results --single-file --clean",
    "setup:husky": "node -e \"try { (await import('husky')).default() } catch (e) { if (e.code !== 'ERR_MODULE_NOT_FOUND') throw e }\" --input-type module",
    "test:smoketest": "cucumber-js --tags \"@smoketest\" ; npm run report",
    "test:tagged": "cucumber-js --tags",
    "test": "cucumber-js --tags \"not @smoketest and not @localonly\" ; npm run report"
  },
  "dependencies": {
    "allure-commandline": "2.43.0",
    "allure-js-commons": "3.10.0",
    "csv-parse": "7.0.0",
    "esm-module-alias": "2.2.1",
    "exceljs": "4.4.0",
    "global-agent": "4.1.3",
    "pino": "10.3.1",
    "undici": "8.5.0"
  },
  "overrides": {
    "tmp": "0.2.7",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/eslint-parser": "7.28.6",
    "@babel/preset-env": "7.29.2",
    "@cucumber/cucumber": "13.0.0",
    "@cucumber/messages": "33.0.2",
    "@faker-js/faker": "10.5.0",
    "@types/node": "26.0.0",
    "allure-cucumberjs": "3.10.0",
    "chai": "6.2.2",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "mongodb": "7.3.0",
    "neostandard": "0.13.0",
    "prettier": "3.8.4",
    "typescript": "6.0.3"
  }
}
